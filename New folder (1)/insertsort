#include <iostream>
#include <vector>
#include <fstream>
#include <chrono>

using namespace std;

void insertionSort(vector<int>& arr) {
    int n = arr.size();
    for (int i = 1; i < n; i++) {
        int key = arr[i];
        int j = i - 1;
        while (j >= 0 && arr[j] > key) {
            arr[j + 1] = arr[j];
            j--;
        }
        arr[j + 1] = key;
    }
}

int main() {
    ifstream f("lista.txt");
    int n; f >> n;
    vector<int> arr(n);
    for(int i=0; i<n; i++) f >> arr[i];
    f.close();

    auto start = chrono::high_resolution_clock::now();
    insertionSort(arr);
    auto end = chrono::high_resolution_clock::now();

    cout << "Insertion Sort: " << chrono::duration<double>(end-start).count() << " secunde" << endl;
    return 0;
}